<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="CourseManager Eğitim Portalı" />
    <meta name="author" content="EduManager" />
    <title>@ViewData["Title"] - CourseManager Portal</title>

    <!-- Google Fonts - Inter Fontu -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Bootstrap 5 & Styles -->
    <link href="~/css/styles.css" rel="stylesheet" />
    <link href="~/css/modern.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <!-- Portal Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-portal sticky-top py-3">
        <div class="container">
            <a class="navbar-brand portal-brand d-flex align-items-center gap-2" href="/">
                <i class="fa-solid fa-graduation-cap text-primary fs-3"></i>
                <span>CourseManager</span>
            </a>
            
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#portalNavbar" aria-controls="portalNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <i class="fas fa-bars text-secondary"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="portalNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item">
                        <a class="nav-link fw-semibold text-dark active" href="/"><i class="fa-solid fa-house me-1 text-muted"></i> Ana Sayfa</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <a href="/Admin/Index" class="btn btn-premium d-inline-flex align-items-center gap-2">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Yönetici Girişi</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="flex-grow-1 py-5">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- Portal Footer -->
    <footer class="py-4 bg-white border-top mt-auto shadow-sm">
        <div class="container">
            <div class="row align-items-center justify-content-between">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-2 mb-1">
                        <i class="fa-solid fa-graduation-cap text-primary"></i>
                        <span class="fw-bold text-dark">CourseManager Academy</span>
                    </div>
                    <p class="small text-muted mb-0">&copy; @DateTime.Now.Year EduManager. Tüm hakları saklıdır.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <div class="d-flex justify-content-center justify-content-md-end gap-4 small">
                        <a href="#!" class="text-decoration-none text-muted hover-primary">Gizlilik Politikası</a>
                        <a href="#!" class="text-decoration-none text-muted hover-primary">Destek & İletişim</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>
