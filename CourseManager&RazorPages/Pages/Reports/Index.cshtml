@page
@model CourseManager_RazorPages.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Analiz & Raporlar";
}

<!-- Başlık ve Karşılama Bölümü -->
<div class="d-flex justify-content-between align-items-center mb-4 animate-fade-in">
    <div>
        <h1 class="fw-bold text-dark mb-1">Analiz & Raporlar</h1>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Admin/Index" class="text-decoration-none">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Raporlar</li>
        </ol>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-premium btn-premium-success d-inline-flex align-items-center gap-2" href="/Reports/Index?handler=ExportExcel">
            <i class="fa-solid fa-file-excel"></i>
            <span>Excel İndir</span>
        </a>
        <a class="btn btn-premium btn-premium-danger d-inline-flex align-items-center gap-2" href="/Reports/Index?handler=ExportPdf">
            <i class="fa-solid fa-file-pdf"></i>
            <span>PDF İndir</span>
        </a>
    </div>
</div>

@if (TempData["RaporHata"] != null)
{
    <div class="alert alert-danger rounded-3 animate-fade-in" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["RaporHata"]
    </div>
}

<h5 class="mb-3 text-secondary fw-semibold animate-fade-in" style="animation-delay: 0.05s;">
    <i class="fa-solid fa-wand-magic-sparkles me-2 text-indigo"></i>Sistem Metrikleri
</h5>

<div class="row g-4 animate-fade-in" style="animation-delay: 0.1s;">
    <!-- Müfredat Değeri -->
    <div class="col-xl-3 col-md-6">
        <div class="metric-card metric-card-primary shadow-sm h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="opacity-75 small fw-semibold text-uppercase d-block mb-1">Müfredat Değeri</span>
                <h3 class="fw-extrabold mb-2 text-dark">@Model.ToplamKursDegeri.ToString("N0") TL</h3>
            </div>
            <p class="mb-0 small text-muted mt-auto pt-3 border-top"><i class="fa-solid fa-wallet me-1 text-primary"></i> Kursların toplam maliyeti</p>
        </div>
    </div>

    <!-- Ortalama Süre -->
    <div class="col-xl-3 col-md-6">
        <div class="metric-card metric-card-success shadow-sm h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="opacity-75 small fw-semibold text-uppercase d-block mb-1">Ortalama Süre</span>
                <h3 class="fw-extrabold mb-2 text-dark">@Model.OrtalamaKursSuresi.ToString("F1") Saat</h3>
            </div>
            <p class="mb-0 small text-muted mt-auto pt-3 border-top"><i class="fa-regular fa-clock me-1 text-success"></i> Kurs başına düşen süre</p>
        </div>
    </div>

    <!-- En Kapsamlı Kurs -->
    <div class="col-xl-3 col-md-6">
        <div class="metric-card metric-card-warning shadow-sm h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="opacity-75 small fw-semibold text-uppercase d-block mb-1">En Kapsamlı Kurs</span>
                <h4 class="fw-extrabold text-dark mb-2 text-truncate" title="@Model.EnUzunKurs">@Model.EnUzunKurs</h4>
            </div>
            <p class="mb-0 small text-muted mt-auto pt-3 border-top"><i class="fa-solid fa-hourglass-high me-1 text-warning"></i> Süre bakımından en uzun kurs</p>
        </div>
    </div>

    <!-- Aylık Kayıt Trendi -->
    <div class="col-xl-3 col-md-6">
        <div class="metric-card metric-card-danger shadow-sm h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="opacity-75 small fw-semibold text-uppercase d-block mb-1">Aylık Kayıt Trendi</span>
                <h3 class="fw-extrabold mb-2 text-dark">+@Model.SonBirAyOgrenci Öğrenci</h3>
            </div>
            <p class="mb-0 small text-muted mt-auto pt-3 border-top"><i class="fa-solid fa-arrow-trend-up text-danger me-1"></i> Son 30 günde katılanlar</p>
        </div>
    </div>
</div>