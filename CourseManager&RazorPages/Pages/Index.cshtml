@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- Başlık ve Karşılama Bölümü -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold text-dark mb-1">Hoş Geldiniz, Admin 👋</h1>
        <p class="text-muted mb-0">Sistemdeki güncel durum ve özet veriler aşağıda listelenmiştir.</p>
    </div>
    <div class="badge bg-light text-dark p-2 border shadow-sm">
        <i class="fa-regular fa-calendar me-2 text-primary"></i>@DateTime.Now.ToString("dd MMMM yyyy")
    </div>
</div>

<!-- MODERN İSTATİSTİK KARTLARI (KPI Cards) -->
<div class="row g-4 mb-5">
    <!-- Öğrenci İstatistiği -->
    <div class="col-xl-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-3 h-100" style="border-left: 4px solid #3b82f6 !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase fw-semibold text-muted small mb-2">Toplam Öğrenci</h6>
                        <h2 class="fw-bold mb-0 text-dark">Aktif</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                        <i class="fa-solid fa-user-graduate fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/Students/Index" class="text-primary text-decoration-none small fw-medium">
                        Öğrencileri Yönet <i class="fa-solid fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Kurs İstatistiği -->
    <div class="col-xl-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-3 h-100" style="border-left: 4px solid #10b981 !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase fw-semibold text-muted small mb-2">Mevcut Kurslar</h6>
                        <h2 class="fw-bold mb-0 text-dark">Aktif</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                        <i class="fa-solid fa-book-bookmark fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/Courses/Index" class="text-success text-decoration-none small fw-medium">
                        Kursları İncele <i class="fa-solid fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Sertifika İstatistiği -->
    <div class="col-xl-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-3 h-100" style="border-left: 4px solid #f59e0b !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase fw-semibold text-muted small mb-2">Verilen Sertifikalar</h6>
                        <h2 class="fw-bold mb-0 text-dark">Kayıtlı</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3">
                        <i class="fa-solid fa-award fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/Certificates/Index" class="text-warning text-decoration-none small fw-medium">
                        Sertifikaları Gör <i class="fa-solid fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- HIZLI ERİŞİM VE AKSİYON ALANI -->
<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-bolt me-2 text-danger"></i>Hızlı İşlemler</h5>
    </div>
    <div class="card-body p-4 pt-2">
        <p class="text-muted small mb-4">Sistem üzerinde sık gerçekleştirdiğiniz işlemlere tek tıkla ulaşın:</p>
        <div class="row g-3">
            <div class="col-md-4">
                <a href="/Students/Create" class="btn btn-outline-primary w-100 py-3 rounded-3 fw-medium">
                    <i class="fa-solid fa-user-plus me-2"></i>Yeni Öğrenci Ekle
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Courses/Create" class="btn btn-outline-success w-100 py-3 rounded-3 fw-medium">
                    <i class="fa-solid fa-folder-plus me-2"></i>Yeni Kurs Tanımla
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Certificates/Create" class="btn btn-outline-warning w-100 py-3 rounded-3 fw-medium text-dark">
                    <i class="fa-solid fa-file-signature me-2"></i>Sertifika Oluştur
                </a>
            </div>
        </div>
    </div>
</div>