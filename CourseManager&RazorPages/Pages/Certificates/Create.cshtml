@page
@model CourseManager_RazorPages.Pages.Certificates.CreateModel
@{
    ViewData["Title"] = "Yeni Sertifika Ekle";
}

<div class="row justify-content-center animate-fade-in">
    <div class="col-lg-8 col-md-10">
        <!-- Breadcrumb -->
        <div class="mb-4">
            <h1 class="fw-bold text-dark mb-1">Yeni Sertifika Tanımla</h1>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Admin/Index" class="text-decoration-none">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a href="/Certificates/Index" class="text-decoration-none">Sertifikalar</a></li>
                <li class="breadcrumb-item active">Yeni Ekle</li>
            </ol>
        </div>

        <div class="card card-premium border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 py-3 d-flex align-items-center gap-2">
                <i class="fas fa-plus-circle text-primary fs-5"></i>
                <h5 class="mb-0 fw-bold text-dark">Sertifika Detayları</h5>
            </div>
            
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Hata:</strong> @Model.errorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="POST">
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Sertifika No</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control form-control-modern" name="CertificateNo" value="@Model.certificateInfo.CertificateNo" placeholder="Örn: CERT-2026-001" required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label fw-semibold">Veriliş Tarihi</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control form-control-modern" name="IssueDate" value="@Model.certificateInfo.IssueDate" />
                        </div>
                    </div>

                    <div class="row pt-2 border-top">
                        <div class="col-sm-9 offset-sm-3 d-flex gap-2">
                            <button type="submit" class="btn btn-premium d-inline-flex align-items-center gap-2">
                                <i class="fas fa-save"></i>
                                <span>Sertifikayı Kaydet</span>
                            </button>
                            <a class="btn btn-outline-secondary d-inline-flex align-items-center justify-content-center px-4 rounded-3" href="/Certificates/Index" role="button">
                                <span>Vazgeç</span>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>