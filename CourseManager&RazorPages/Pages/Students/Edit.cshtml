@page
@model CourseManager_RazorPages.Pages.Students.EditModel
@{
    ViewData["Title"] = "Öğrenci Bilgilerini Düzenle";
}

<div class="row justify-content-center animate-fade-in">
    <div class="col-lg-8 col-md-10">
        <!-- Breadcrumb -->
        <div class="mb-4">
            <h1 class="fw-bold text-dark mb-1">Öğrenci Bilgilerini Düzenle</h1>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Admin/Index" class="text-decoration-none">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a href="/Students/Index" class="text-decoration-none">Öğrenciler</a></li>
                <li class="breadcrumb-item active">Düzenle</li>
            </ol>
        </div>

        <div class="card card-premium border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 py-3 d-flex align-items-center gap-2">
                <i class="fas fa-user-edit text-warning fs-5"></i>
                <h5 class="mb-0 fw-bold text-dark">Bilgileri Güncelle</h5>
            </div>
            
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Hata:</strong> @Model.errorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="POST">
                    <input type="hidden" name="StudentID" value="@Model.studentInfo.StudentID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Adı</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control form-control-modern" name="FirstName" value="@Model.studentInfo.FirstName" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Soyadı</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control form-control-modern" name="LastName" value="@Model.studentInfo.LastName" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">E-posta</label>
                        <div class="col-sm-9">
                            <input type="email" class="form-control form-control-modern" name="Email" value="@Model.studentInfo.Email" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Telefon</label>
                        <div class="col-sm-9">
                            <input type="tel" class="form-control form-control-modern" name="Phone" value="@Model.studentInfo.Phone" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label fw-semibold">Kayıt Tarihi</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control form-control-modern" name="RegistrationDate" value="@Model.studentInfo.RegistrationDate" />
                        </div>
                    </div>

                    <div class="row pt-2 border-top">
                        <div class="col-sm-9 offset-sm-3 d-flex gap-2">
                            <button type="submit" class="btn btn-premium btn-premium-warning d-inline-flex align-items-center gap-2 text-dark">
                                <i class="fas fa-save"></i>
                                <span>Değişiklikleri Kaydet</span>
                            </button>
                            <a class="btn btn-outline-secondary d-inline-flex align-items-center justify-content-center px-4 rounded-3" href="/Students/Index" role="button">
                                <span>İptal</span>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>