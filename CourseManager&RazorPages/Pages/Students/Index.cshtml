@page
@model CourseManager_RazorPages.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-4 animate-fade-in">
    <div>
        <h1 class="fw-bold text-dark mb-1">Öğrenci Yönetimi</h1>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Admin/Index" class="text-decoration-none">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Öğrenciler</li>
        </ol>
    </div>
    <a href="/Students/Create" class="btn btn-premium d-inline-flex align-items-center gap-2">
        <i class="fas fa-plus"></i>
        <span>Yeni Öğrenci Ekle</span>
    </a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 animate-fade-in" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Hata!</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-premium border-0 shadow-sm rounded-3 animate-fade-in" style="animation-delay: 0.1s;">
    <div class="card-body p-4">
        <!-- Arama Alanı -->
        <div class="row mb-4">
            <div class="col-md-8">
                <form method="get">
                    <div class="input-group">
                        <input type="text" class="form-control form-control-modern" name="search" value="@Model.AramaKelimesi" placeholder="Öğrenci adı, soyadı veya e-posta ara...">
                        <button class="btn btn-premium" type="submit">
                            <i class="fas fa-search me-1"></i> Ara
                        </button>
                        <a href="/Students/Index" class="btn btn-outline-secondary d-inline-flex align-items-center justify-content-center px-3 ms-2 rounded-3">
                            <i class="fas fa-eraser me-1"></i> Temizle
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Kayıt Tarihi</th>
                        <th class="text-center" style="width: 220px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.listele != null && Model.listele.Count > 0)
                    {
                        foreach (var student in Model.listele)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-weight: 600;">
                                            @student.FirstName?[0]@student.LastName?[0]
                                        </div>
                                        <strong>@student.FirstName @student.LastName</strong>
                                    </div>
                                </td>
                                <td>@student.Email</td>
                                <td>@(string.IsNullOrEmpty(student.Phone) ? "-" : student.Phone)</td>
                                <td>@student.RegistrationDate</td>
                                <td class="text-center">
                                    <div class="btn-group gap-1" role="group">
                                        <a href="/Students/Edit?StudentID=@student.StudentID" class="btn btn-sm btn-premium btn-premium-warning py-1.5 px-3 rounded-2 text-dark" title="Düzenle">
                                            <i class="fas fa-edit me-1"></i> Düzenle
                                        </a>
                                        <a href="/Students/Index?handler=Delete&StudentID=@student.StudentID"
                                           class="btn btn-sm btn-premium btn-premium-danger py-1.5 px-3 rounded-2"
                                           title="Sil"
                                           onclick="return confirm('@student.FirstName @student.LastName isimli öğrenciyi silmek istediğinize emin misiniz?');">
                                            <i class="fas fa-trash me-1"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="fas fa-info-circle fa-2x mb-3 d-block text-secondary"></i>
                                Kayıtlı öğrenci veya arama kriterine uygun sonuç bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>