@page
@model CourseManager_RazorPages.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Kurs Listesi";
    ViewData["PageTitle"] = "Kurslar";
}

<h1 class="mt-4">@ViewData["PageTitle"]</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
    <li class="breadcrumb-item active">Kurslar</li>
</ol>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Hata!</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-book me-1"></i>
            Kurs Yönetimi
        </div>
        <a href="/Courses/Create" class="btn btn-primary btn-sm">
            <i class="fas fa-plus"></i> Yeni Kurs Ekle
        </a>
    </div>

    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-8">
                <form method="get">
                    <div class="input-group">
                        <input type="text" class="form-control" name="search" value="@Model.AramaKelimesi" placeholder="Kurs adı veya eğitmen ara..." aria-label="Arama">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search me-1"></i> Ara
                        </button>
                        <a href="/Courses/Index" class="btn btn-outline-secondary">
                            <i class="fas fa-eraser me-1"></i> Temizle
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Kurs Adı</th>
                        <th>Eğitmen</th>
                        <th>Süre (Saat)</th>
                        <th>Fiyat (TL)</th>
                        <th>Başlangıç Tarihi</th>
                        <th class="text-center" style="width: 220px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.listele != null && Model.listele.Count > 0)
                    {
                        foreach (var course in Model.listele)
                        {
                            <tr>
                                <td><strong>@course.CourseName</strong></td>
                                <td>@course.Instructor</td>
                                <td>@course.Duration Saat</td>
                                <td class="fw-bold text-success">@course.Price TL</td>
                                <td>@course.StartDate</td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="/Courses/Edit?CoursesID=@course.CoursesID" class="btn btn-warning">
                                            <i class="fas fa-edit"></i> Düzenle
                                        </a>
                                        <a href="/Courses/Delete?CoursesID=@course.CoursesID"
                                           class="btn btn-danger"
                                           onclick="return confirm('@course.CourseName kursunu silmek istediğinize emin misiniz?');">
                                            <i class="fas fa-trash"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="fas fa-info-circle fa-2x mb-3 d-block"></i>
                                Kayıtlı kurs veya arama kriterine uygun sonuç bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>