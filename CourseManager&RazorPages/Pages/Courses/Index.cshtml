@page
@model CourseManager_RazorPages.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Kurs Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-4 animate-fade-in">
    <div>
        <h1 class="fw-bold text-dark mb-1">Kurs Yönetimi</h1>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Admin/Index" class="text-decoration-none">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Kurslar</li>
        </ol>
    </div>
    <a href="/Courses/Create" class="btn btn-premium d-inline-flex align-items-center gap-2">
        <i class="fas fa-plus"></i>
        <span>Yeni Kurs Ekle</span>
    </a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 animate-fade-in" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Hata!</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-premium border-0 shadow-sm rounded-3 animate-fade-in" style="animation-delay: 0.1s;">
    <div class="card-body p-4">
        <!-- Arama Alanı -->
        <div class="row mb-4">
            <div class="col-md-8">
                <form method="get">
                    <div class="input-group">
                        <input type="text" class="form-control form-control-modern" name="search" value="@Model.AramaKelimesi" placeholder="Kurs adı veya eğitmen ara...">
                        <button class="btn btn-premium" type="submit">
                            <i class="fas fa-search me-1"></i> Ara
                        </button>
                        <a href="/Courses/Index" class="btn btn-outline-secondary d-inline-flex align-items-center justify-content-center px-3 ms-2 rounded-3">
                            <i class="fas fa-eraser me-1"></i> Temizle
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-modern table-hover align-middle">
                <thead>
                    <tr>
                        <th>Kurs Adı</th>
                        <th>Eğitmen</th>
                        <th>Süre (Saat)</th>
                        <th>Fiyat (TL)</th>
                        <th>Başlangıç Tarihi</th>
                        <th class="text-center" style="width: 220px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.listele != null && Model.listele.Count > 0)
                    {
                        foreach (var course in Model.listele)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                            <i class="fa-solid fa-book-bookmark text-success"></i>
                                        </div>
                                        <strong>@course.CourseName</strong>
                                    </div>
                                </td>
                                <td>@course.Instructor</td>
                                <td><span class="badge bg-light text-dark border">@course.Duration Saat</span></td>
                                <td class="fw-bold text-success">@course.Price TL</td>
                                <td>@course.StartDate</td>
                                <td class="text-center">
                                    <div class="btn-group gap-1" role="group">
                                        <a href="/Courses/Edit?CoursesID=@course.CoursesID" class="btn btn-sm btn-premium btn-premium-warning py-1.5 px-3 rounded-2 text-dark" title="Düzenle">
                                            <i class="fas fa-edit me-1"></i> Düzenle
                                        </a>
                                        <a href="/Courses/Index?handler=Delete&CoursesID=@course.CoursesID"
                                           class="btn btn-sm btn-premium btn-premium-danger py-1.5 px-3 rounded-2"
                                           title="Sil"
                                           onclick="return confirm('@course.CourseName kursunu silmek istediğinize emin misiniz?');">
                                            <i class="fas fa-trash me-1"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fas fa-info-circle fa-2x mb-3 d-block text-secondary"></i>
                                Kayıtlı kurs veya arama kriterine uygun sonuç bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>